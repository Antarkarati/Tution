module bcd_ex3 (input [3:0]a,
                 								output [3:0]b);

wire w1,w2;
not(b[0],a[0]);
xnor(b[1],a[0],a[1]);
or(w1,a[0],a[1]);
xor(b[2],w1,a[2]);
and(w2,a[2],w1);
or(b[3],w2,a[3]);

endmodule

module test_bcd();
