bcd to excess3:::


module BCD_to_excess3(bcd,ex);
	input [3:0]bcd;
	output [3:0]ex;
	wire l,k;
	not(ex[0],bcd[0]);
	xnor(ex[1],bcd[0],bcd[1]);
	or(k,bcd[0],bcd[1]);
	xor(ex[2],bcd[2],k);
	and(l,bcd[2],k);
	or(ex[3],bcd[3],l);
endmodule


`timescale 1ns/1ps
module tb_BCD_to_excess3();

	reg [3:0]bcd;
	wire [3:0]ex;
	
	BCD_to_excess3 uut(bcd,ex);
	initial begin
		bcd=4'd5;
		#10;
		
		bcd=4'd9;
		#10;
		
		bcd=4'd2;
		#10;
		$stop;
	end
endmodule
